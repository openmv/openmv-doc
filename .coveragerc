# Coverage is scoped to the first-party Python tooling we actually test. The
# remaining .ci scripts are excluded for now: optimize_images/minify_docs are
# thin wrappers around Pillow/minify-html (testing them tests those libs),
# find_dupes is a read-only diagnostic that isn't in the build pipeline, and
# dedup_assets is a larger cross-locale asset rewriter still to be covered.
[run]
omit =
    */dedup_assets.py
    */find_dupes.py
    */optimize_images.py
    */minify_docs.py

[report]
show_missing = true
